          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Status Reembolsado (string)', () => pm.expect(pm.response.json().status).to.eql('Reembolsado'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/v1/payment/{{payment_id}}/reembolso", "host": ["{{base_url}}"], "path": ["v1","payment","{{payment_id}}","reembolso"] }
          }
        },
        {
          "name": "5.5 Reembolso Duplo — 400",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('Mensagem de erro', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.hasOwnProperty('Message') || j.hasOwnProperty('message')).to.be.true;",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/v1/payment/{{payment_id}}/reembolso", "host": ["{{base_url}}"], "path": ["v1","payment","{{payment_id}}","reembolso"] }
          }
        }
      ]
    },

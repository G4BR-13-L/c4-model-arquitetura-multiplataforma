    {
      "name": "7. Kong Admin",
      "item": [
        {
          "name": "7.1 Status do Kong",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('DB acessível', () => pm.expect(pm.response.json().database.reachable).to.be.true);"
          ], "type": "text/javascript" }}],
          "request": { "method": "GET", "url": { "raw": "{{admin_url}}/status", "host": ["{{admin_url}}"], "path": ["status"] } }
        },
        {
          "name": "7.2 Listar Services",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('5 services', () => pm.expect(pm.response.json().data.length).to.eql(5));",
            "pm.test('Todos existem', () => { const n = pm.response.json().data.map(s => s.name); ['user-service','vehicle-service','rental-service','payment-service','notification-service'].forEach(x => pm.expect(n).to.include(x)); });"
          ], "type": "text/javascript" }}],
          "request": { "method": "GET", "url": { "raw": "{{admin_url}}/services", "host": ["{{admin_url}}"], "path": ["services"] } }
        },
        {
          "name": "7.3 Listar Routes",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('6 routes', () => pm.expect(pm.response.json().data.length).to.eql(6));",

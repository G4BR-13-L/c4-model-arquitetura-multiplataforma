{
  "info": {
    "name": "Plataforma de Locação — FINAL v3",
    "description": "Collection definitiva. Rode 2.1 isolado primeiro se for primeira vez. Depois todos os 36 no Runner com Delay 300ms.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",     "value": "http://localhost:8000" },
    { "key": "admin_url",    "value": "http://localhost:8001" },
    { "key": "access_token", "value": "" },
    { "key": "user_id",      "value": "" },
    { "key": "vehicle_id",   "value": "" },
    { "key": "rental_id",    "value": "" },
    { "key": "payment_id",   "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "1.1 Gerar Token JWT",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Tem access_token', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j).to.have.property('access_token');",
            "  pm.collectionVariables.set('access_token', j.access_token);",
            "  console.log('Token salvo OK');",
            "});",
            "pm.test('Via Kong', () => pm.expect(pm.response.headers.get('Via')).to.include('kong'));",
            "pm.test('Rate limit ativo', () => pm.expect(pm.response.headers.get('X-RateLimit-Limit-Minute')).to.eql('100'));",
            "pm.test('CORS ativo', () => pm.expect(pm.response.headers.get('Access-Control-Allow-Credentials')).to.eql('true'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"userName\": \"testuser\",\n  \"password\": \"Test@123\"\n}" },
            "url": { "raw": "{{base_url}}/v1/auth/token", "host": ["{{base_url}}"], "path": ["v1","auth","token"] }
          }
        },
        {
          "name": "1.2 Credenciais Inválidas — 400",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('Mensagem de erro', () => {",
            "  const j = pm.response.json();",
            "  // .NET serializa em camelCase: 'message' (minúsculo)",
            "  const temMensagem = j.hasOwnProperty('message') || j.hasOwnProperty('Message');",
            "  pm.expect(temMensagem).to.be.true;",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"userName\": \"usuario_invalido\",\n  \"password\": \"senha_errada\"\n}" },
            "url": { "raw": "{{base_url}}/v1/auth/token", "host": ["{{base_url}}"], "path": ["v1","auth","token"] }
          }
        }
      ]
    },
    {
      "name": "2. User Service",
      "item": [
        {
          "name": "2.1 Criar Usuário (idempotente)",
          "event": [{ "listen": "test", "script": { "exec": [
            "// Aceita 200 tanto para usuário novo quanto para usuário já existente",
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Tem id e username', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j).to.have.property('id');",
            "  pm.expect(j).to.have.property('username');",
            "  pm.collectionVariables.set('user_id', j.id);",
            "  console.log('user_id:', j.id);",
            "});",
            "pm.test('Via Kong', () => pm.expect(pm.response.headers.get('Via')).to.include('kong'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"userName\": \"testuser\",\n  \"email\": \"test@locacao.com\",\n  \"password\": \"Test@123\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\"\n}" },
            "url": { "raw": "{{base_url}}/v1/user", "host": ["{{base_url}}"], "path": ["v1","user"] }
          }
        },
        {
          "name": "2.2 Buscar Usuário por ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('ID correto', () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('user_id')));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/v1/user/{{user_id}}", "host": ["{{base_url}}"], "path": ["v1","user","{{user_id}}"] }
          }
        },
        {
          "name": "2.3 Atualizar Usuário",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Test Updated\",\n  \"lastName\": \"User Updated\",\n  \"email\": \"updated@locacao.com\"\n}" },
            "url": { "raw": "{{base_url}}/v1/user/{{user_id}}", "host": ["{{base_url}}"], "path": ["v1","user","{{user_id}}"] }
          }
        },
        {
          "name": "2.4 Usuário não encontrado — 404",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 404', () => pm.response.to.have.status(404));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/v1/user/00000000-0000-0000-0000-000000000000", "host": ["{{base_url}}"], "path": ["v1","user","00000000-0000-0000-0000-000000000000"] }
          }
        }
      ]
    },
    {
      "name": "3. Vehicle Service",
      "item": [
        {
          "name": "3.1 Cadastrar Veículo",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Tem ID e placa', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j).to.have.property('id');",
            "  pm.expect(j.placa).to.eql('ABC-1234');",
            "  pm.expect(j.disponivel).to.be.true;",
            "  pm.collectionVariables.set('vehicle_id', j.id);",
            "  console.log('vehicle_id:', j.id);",
            "});",
            "pm.test('Via Kong', () => pm.expect(pm.response.headers.get('Via')).to.include('kong'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"placa\": \"ABC-1234\",\n  \"modelo\": \"Toyota Corolla\",\n  \"ano\": 2023,\n  \"categoria\": \"Sedan\",\n  \"valorDiaria\": 150.00,\n  \"disponivel\": true\n}" },
            "url": { "raw": "{{base_url}}/v1/vehicle", "host": ["{{base_url}}"], "path": ["v1","vehicle"] }
          }
        },
        {
          "name": "3.2 Listar Veículos",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Retorna array', () => pm.expect(pm.response.json()).to.be.an('array'));",
            "pm.test('Via Kong', () => pm.expect(pm.response.headers.get('Via')).to.include('kong'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/v1/vehicle", "host": ["{{base_url}}"], "path": ["v1","vehicle"] }
          }
        },
        {
          "name": "3.3 Filtrar Disponíveis",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Todos disponíveis', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j).to.be.an('array');",
            "  j.forEach(v => pm.expect(v.disponivel).to.be.true);",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/v1/vehicle?disponivel=true", "host": ["{{base_url}}"], "path": ["v1","vehicle"], "query": [{"key":"disponivel","value":"true"}] }
          }
        },
        {
          "name": "3.4 Buscar por ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('ID correto', () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('vehicle_id')));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/v1/vehicle/{{vehicle_id}}", "host": ["{{base_url}}"], "path": ["v1","vehicle","{{vehicle_id}}"] }
          }
        },
        {
          "name": "3.5 Atualizar Veículo",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Valor atualizado', () => pm.expect(pm.response.json().valorDiaria).to.eql(175.00));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"valorDiaria\": 175.00\n}" },
            "url": { "raw": "{{base_url}}/v1/vehicle/{{vehicle_id}}", "host": ["{{base_url}}"], "path": ["v1","vehicle","{{vehicle_id}}"] }
          }
        },
        {
          "name": "3.6 Veículo não encontrado — 404",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 404', () => pm.response.to.have.status(404));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/v1/vehicle/00000000-0000-0000-0000-000000000000", "host": ["{{base_url}}"], "path": ["v1","vehicle","00000000-0000-0000-0000-000000000000"] }
          }
        }
      ]
    },
    {
      "name": "4. Rental Service",
      "item": [
        {
          "name": "4.1 Criar Reserva",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Status Pendente (string) e valorTotal > 0', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j).to.have.property('id');",
            "  pm.expect(j.status).to.eql('Pendente');",
            "  pm.expect(j.valorTotal).to.be.greaterThan(0);",
            "  pm.collectionVariables.set('rental_id', j.id);",
            "  console.log('rental_id:', j.id, '| valorTotal:', j.valorTotal);",
            "});",
            "pm.test('Via Kong', () => pm.expect(pm.response.headers.get('Via')).to.include('kong'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"usuarioId\": \"{{user_id}}\",\n  \"veiculoId\": \"{{vehicle_id}}\",\n  \"dataInicio\": \"2026-04-01\",\n  \"dataFim\": \"2026-04-05\",\n  \"valorDiaria\": 150.00\n}" },
            "url": { "raw": "{{base_url}}/v1/rental", "host": ["{{base_url}}"], "path": ["v1","rental"] }
          }
        },
        {
          "name": "4.2 Buscar Reserva por ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('ID correto', () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('rental_id')));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/v1/rental/{{rental_id}}", "host": ["{{base_url}}"], "path": ["v1","rental","{{rental_id}}"] }
          }
        },
        {
          "name": "4.3 Listar Reservas do Usuário",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Array com pelo menos 1', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j).to.be.an('array');",
            "  pm.expect(j.length).to.be.at.least(1);",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/v1/rental?usuarioId={{user_id}}", "host": ["{{base_url}}"], "path": ["v1","rental"], "query": [{"key":"usuarioId","value":"{{user_id}}"}] }
          }
        },
        {
          "name": "4.4 Concluir Locação",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Status Concluido (string)', () => pm.expect(pm.response.json().status).to.eql('Concluido'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/v1/rental/{{rental_id}}/concluir", "host": ["{{base_url}}"], "path": ["v1","rental","{{rental_id}}","concluir"] }
          }
        },
        {
          "name": "4.5 Cancelar Concluída — 400",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('Mensagem de erro', () => {",
            "  const j = pm.response.json();",
            "  const temMsg = j.hasOwnProperty('Message') || j.hasOwnProperty('message');",
            "  pm.expect(temMsg).to.be.true;",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/v1/rental/{{rental_id}}/cancelar", "host": ["{{base_url}}"], "path": ["v1","rental","{{rental_id}}","cancelar"] }
          }
        }
      ]
    },
    {
      "name": "5. Payment Service",
      "item": [
        {
          "name": "5.1 Processar Pagamento — Aprovado",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Status Confirmado (string) + TXN ID', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j).to.have.property('id');",
            "  pm.expect(j.status).to.eql('Confirmado');",
            "  pm.expect(j.gatewayTransactionId).to.include('FAKE-TXN');",
            "  pm.collectionVariables.set('payment_id', j.id);",
            "  console.log('payment_id:', j.id);",
            "});",
            "pm.test('Via Kong', () => pm.expect(pm.response.headers.get('Via')).to.include('kong'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"locacaoId\": \"{{rental_id}}\",\n  \"valor\": 600.00,\n  \"metodoPagamento\": \"CartaoCredito\",\n  \"numeroCartao\": \"4111111111111111\",\n  \"validade\": \"12/28\",\n  \"cvv\": \"123\"\n}" },
            "url": { "raw": "{{base_url}}/v1/payment", "host": ["{{base_url}}"], "path": ["v1","payment"] }
          }
        },
        {
          "name": "5.2 Pagamento Recusado — 422",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 422', () => pm.response.to.have.status(422));",
            "pm.test('Status Falhou (string)', () => pm.expect(pm.response.json().payment.status).to.eql('Falhou'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"locacaoId\": \"{{rental_id}}\",\n  \"valor\": 99999.99,\n  \"metodoPagamento\": \"CartaoCredito\"\n}" },
            "url": { "raw": "{{base_url}}/v1/payment", "host": ["{{base_url}}"], "path": ["v1","payment"] }
          }
        },
        {
          "name": "5.3 Consultar Status",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('ID correto e tem status', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.id).to.eql(pm.collectionVariables.get('payment_id'));",
            "  pm.expect(j).to.have.property('status');",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/v1/payment/{{payment_id}}", "host": ["{{base_url}}"], "path": ["v1","payment","{{payment_id}}"] }
          }
